# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (BACKEND ONLY - never expose to client)
# Get from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# OpenRouter API (Primary - Recommended)
# Free account: https://openrouter.ai
# Model: x-ai/grok-4.1-fast (free)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Google Gemini API (Fallback)
# Free API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyxxx

# Groq API (Market Analysis)
# API key: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxx

# Fal AI (Virtual Staging / Image Processing)
# API key: https://fal.ai/dashboard/keys
FAL_KEY=fal_xxx

# Admin Panel Security
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secure_password_here

# Security Rate Limits (optional, defaults provided)
# API_RATE_LIMIT_IP_MAX=60
# API_RATE_LIMIT_WINDOW_MS=60000
# API_RATE_LIMIT_USER_MAX=30
# API_DAILY_SPEND_LIMIT=1
# API_DEFAULT_REQUEST_COST=0.35

# Gotenberg (PDF Generation - BACKEND ONLY)
# GOTENBERG_URL=http://localhost:3001
